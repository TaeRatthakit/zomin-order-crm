NODE_ENV=production
PORT=3000

# Use json for local testing. Use supabase in production/Vercel.
DATABASE_PROVIDER=supabase
JSON_DB_PATH=./data/db.json

# Required when NODE_ENV=production. Generate with: openssl rand -base64 32
# SESSION_SECRET is used first. JWT_SECRET is accepted as a fallback alias.
SESSION_SECRET=
JWT_SECRET=

# Required when DATABASE_PROVIDER=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional/reserved. The current server uses the service role key only.
SUPABASE_ANON_KEY=
DATABASE_URL=

# Optional LINE OA production configuration.
# You can also set these later from the Admin Settings screen, but Vercel ENV is safer for secrets.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_ENABLED=false
